class TodoItem {
    property id;
    property text;
    property done;

    function init(id, text, done = false) {
        this.id = id
        this.text = text
        this.done = done
        return this
    }

    function toggle() {
        this.done = !this.done
        return this
    }

    function toStruct() {
        return {
            id: this.id,
            text: this.text,
            done: this.done
        }
    }
}
